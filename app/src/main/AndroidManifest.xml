<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.mealplannerapp"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MealPlannerApp"
        tools:targetApi="31">

        <activity
            android:name=".activities.LoginActivity"
            android:exported="true">
        <intent-filter>
            <action android:name="android.intent.action.MAIN"/>
            <category android:name="android.intent.category.LAUNCHER"/>
        </intent-filter>
        </activity>

        <activity android:name=".activities.SignupActivity"
            android:exported="true"/>

        <activity
            android:name=".activities.PlanMealActivity"
            android:exported="true" />

        <activity android:name=".activities.RecommendedMealsActivity"
            android:exported="true"/>

        <activity android:name=".activities.RecipeDetailActivity"
            android:exported="true"/>

        <activity
            android:name=".activities.GroceryActivity"
            android:exported="true" />

        <activity
            android:name=".activities.MainActivity"
            android:exported="true">
        </activity>
        <activity android:name=".activities.HomeActivity"
            android:exported="true"/>

        <activity
            android:name=".activities.ProfileActivity"
            android:exported="true"/>
        <activity android:name=".activities.CustomizeMealActivity"
            android:exported="true" />
        <activity android:name=".activities.WeekMealPlanActivity"
            android:exported="true"/>
        <activity android:name=".activities.WeekPlanActivity"
            android:exported="true"/>
        <activity android:name=".activities.ScanActivity"
            android:exported="true"/>
        <activity android:name=".activities.RecipesActivity"
            android:exported="true"/>
        <activity android:name=".activities.ReminderActivity"
            android:exported="true"/>
        <receiver android:name=".notifications.ReminderReceiver"
            android:exported="false"/>
        <activity android:name=".activities.FitnessDetailActivity"
            android:exported="true"/>
        <activity android:name=".activities.FitnessActivity"
            android:exported="true"/>
        <activity android:name=".activities.FavoritesActivity"
            android:exported="true"/>
        <activity android:name=".activities.SettingsActivity"
            android:exported="true"/>
        <activity android:name=".activities.EditProfileActivity"
            android:exported="true"/>
        <activity android:name=".activities.AiChatActivity"
            android:exported="true"/>
        <activity android:name=".activities.AiRecipesActivity"
            android:exported="true"/>

    </application>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false"/>
</manifest>

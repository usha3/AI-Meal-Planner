<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    >

    <!-- HEADER -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Good Morning, Usha 👋"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/subTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your AI food planner is ready"
        android:textSize="13sp"
        android:textColor="#6B7280"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- SEARCH BAR (Material Style) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/subTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/searchRecipes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="Search meals, cuisine, calories..."
            android:padding="14dp"
            android:background="@android:color/transparent"
            android:drawableStart="@android:drawable/ic_menu_search"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- AI CARD (ChatGPT style gradient card) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/aiCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ai_gradient"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/aiSuggestionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍝 AI Suggestion: Creamy Pasta Bowl"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Based on your past meals &amp; preferences"
                android:textColor="#E5E7EB"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- FILTER CHIPS -->
    <HorizontalScrollView
        android:id="@+id/chipScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/aiCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBreakfast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Breakfast"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipLunch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lunch"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dinner"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipProtein"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High Protein"/>

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- ACTION BUTTON ROW (ChatGPT style pills) -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="16dp"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/chipScroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerateDay"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="⚡ Generate Day"
            app:cornerRadius="16dp"
            android:backgroundTint="#4F46E5"
            android:textColor="#FFFFFF"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUsePlan"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="✔ Save Plan"
            app:cornerRadius="16dp"
            android:backgroundTint="#10B981"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- RECYCLER (Card-like container feel) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recipeRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        android:paddingLeft="10dp"
        app:layout_constraintTop_toBottomOf="@id/buttonRow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
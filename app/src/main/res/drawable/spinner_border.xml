<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#F5F5F5"/>

    <!-- Border -->
    <stroke
        android:width="1dp"
        android:color="#000000"/>

    <!-- Rounded corners (optional) -->
    <corners android:radius="2dp"/>

    <!-- Padding inside spinner -->
    <padding
        android:left="4dp"
        android:top="0dp"
        android:right="10dp"
        android:bottom="0dp"/>
</shape>
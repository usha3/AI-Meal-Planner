<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MealPlannerApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>
        <item name="android:windowBackground">@color/white</item>
    </style>
    <!-- styles.xml -->
    <style name="dayLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#888888</item>
    </style>

    <style name="GridRow">
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="GridHeader">
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">6dp</item>
    </style>

    <style name="GridLabel">
        <item name="android:gravity">center_vertical</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">6dp</item>
    </style>

    <style name="GridCell">
        <item name="android:background">@android:drawable/edit_text</item>
        <item name="android:padding">6dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="DayHeader">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FF0000</item>
        <item name="android:textSize">18sp</item>
        <item name="android:background">@drawable/cell_border</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="MealHeader">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#006400</item>
        <item name="android:textSize">18sp</item>
        <item name="android:background">@drawable/cell_border</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="TableCell">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:gravity">top|start</item>
        <item name="android:inputType">textMultiLine</item>
        <item name="maxLines">3</item>
        <item name="android:scrollbars">vertical</item>
        <item name="android:overScrollMode">always</item>
        <item name="android:padding">6dp</item>
        <item name="android:background">@drawable/cell_border</item>
    </style>

    <style name="SpinnerStyle">
        <item name="android:textColor">#000000</item>
        <item name="android:padding">8dp</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@android:drawable/spinner_background</item>
    </style>
    <style name="BottomNavText" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:paddingTop">6dp</item>
    </style>
</resources>